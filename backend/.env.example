# Copy this file to backend/.env and fill in values as needed.
# backend/.env is gitignored and must never be committed.

# ── OCR (optional) ──────────────────────────────────────────────────────────
# OCR.space API key, used for the "scan packing list" feature.
# Get a free key at https://ocr.space/ocrapi
# Leave empty to disable OCR (the feature quietly no-ops when unset).
OCR_SPACE_API_KEY=

# ── Backups ─────────────────────────────────────────────────────────────────
# Folder manual backups are copied into.
# Local use: leave as "backups" (relative to backend/).
# Real deployment: point at a persistent disk or synced cloud folder.
BACKUP_DIR=backups

# ── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Leave unset to use the default
# (backend/operations_demo.db). Override to point at a persistent disk
# mount, e.g. DB_PATH=/var/data/operations_demo.db
DB_PATH=

# ── Demo mode ───────────────────────────────────────────────────────────────
# When true (default), the app reseeds itself with fresh sample data on
# every restart and exposes a "reset demo data" endpoint the frontend can
# call. Set to false for local/private use if you don't want data wiped
# on restart.
DEMO_MODE=true

# ── Server ──────────────────────────────────────────────────────────────────
# Port the Flask/gunicorn server listens on. Most hosting platforms set
# this automatically -- you usually don't need to set it yourself.
PORT=5001

# Enables Flask's debug mode (auto-reload, interactive debugger).
# Keep this false for any public deployment.
FLASK_DEBUG=false

# CORS: which origin(s) may call the API. "*" is fine for this demo since
# there's no auth or sensitive data. Tighten this if you add either.
ALLOWED_ORIGIN=*
